# Supabase project settings (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — never expose to the browser. Used to resolve private client
# report links (bypasses RLS after the token itself has been validated).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Base URL used when building private report links shown to admins, and the
# Google OAuth callback redirect.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Only Google accounts on this email domain are allowed to complete admin
# sign-in — anyone else is signed back out immediately after OAuth. Leave
# unset to allow any Google account (not recommended).
ADMIN_EMAIL_DOMAIN=yourcompany.com
